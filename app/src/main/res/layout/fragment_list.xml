<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_main"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="24dp">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_icon_btn"
            android:src="@drawable/ic_back"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/title_challenges"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.15"
            android:fontFamily="monospace"
            android:textAllCaps="true" />
    </RelativeLayout>

    <!-- Challenge List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_challenges"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- Add Button -->
    <TextView
        android:id="@+id/btn_add"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_btn_add"
        android:text="@string/btn_add_challenge"
        android:textSize="13sp"
        android:textColor="@color/indigo_light"
        android:letterSpacing="0.1"
        android:fontFamily="monospace"
        android:gravity="center"
        android:padding="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="20dp" />

</LinearLayout>
